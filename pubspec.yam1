name: video_editor_pro
description: Video Editor Pro App
version: 1.0.0+1
environment:
  sdk: '>=3.0.0 <4.0.0'
dependencies:
  flutter:
    sdk: flutter
  google_fonts: ^6.1.0
  file_picker: ^6.1.7
  path_provider: ^2.1.3
  video_player: ^2.8.2
  ffmpeg_kit_flutter_min_gpl: ^5.1
flutter:
  uses-material-design: true
